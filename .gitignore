# Repository .gitignore

# Local editor/workspace files
ai-worker-platform.code-workspace

# Local prompts and scratch material
prompts/

# Environment and secrets
.env
.env.*
!.env.example
.venv/

# Node dependencies and build output
node_modules/
backend/node_modules/
frontend/node_modules/
dist/
backend/dist/
frontend/dist/

# Logs and runtime output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local runtime storage: keep placeholders only
storage/jobs/*
storage/assets/*
storage/outputs/*
storage/temp/*
!storage/jobs/.gitkeep
!storage/assets/.gitkeep
!storage/outputs/.gitkeep
!storage/temp/.gitkeep
